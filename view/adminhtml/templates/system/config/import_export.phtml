<script>
require([
    'jquery',
    'Magento_Ui/js/modal/alert',
    'mage/translate',
    'domReady!'
], function ($, alert, $t) {
    'use strict';

    var importUrl = '<?= $block->escapeUrl($block->getImportUrl()) ?>';
    var exportUrl = '<?= $block->escapeUrl($block->getExportUrl()) ?>';
    var sampleUrl = '<?= $block->escapeUrl($block->getSampleUrl()) ?>';

    // File input - show selected filename
    $('#zipcode-import-file').on('change', function() {
        var fileName = $(this).val().split('\\').pop();
        if (fileName) {
            $('#zipcode-file-name').text(fileName).show();
            $('.zipcode-file-text').text($t('File selected:'));
        } else {
            $('#zipcode-file-name').text('').hide();
            $('.zipcode-file-text').text($t('Choose JSON file...'));
        }
    });

    // Export functionality
    $('#zipcode-export-btn').on('click', function() {
        window.location.href = exportUrl;
    });

    // Download sample functionality
    $('#zipcode-sample-btn').on('click', function() {
        window.location.href = sampleUrl;
    });

    // Import functionality
    $('#zipcode-import-btn').on('click', function() {
        var fileInput = document.getElementById('zipcode-import-file');
        var resultDiv = $('#import-result');

        if (!fileInput.files || fileInput.files.length === 0) {
            alert({
                title: $t('Error'),
                content: $t('Please select a JSON file to import.')
            });
            return;
        }

        var file = fileInput.files[0];

        // Check file extension
        if (!file.name.endsWith('.json')) {
            alert({
                title: $t('Error'),
                content: $t('Please select a valid JSON file.')
            });
            return;
        }

        // Read file
        var reader = new FileReader();
        reader.onload = function(e) {
            try {
                var jsonData = e.target.result;

                // Validate JSON
                try {
                    JSON.parse(jsonData);
                } catch (parseError) {
                    alert({
                        title: $t('Error'),
                        content: $t('Invalid JSON format: ') + parseError.message
                    });
                    return;
                }

                // Show loading
                resultDiv.html('<div class="message message-notice"><span>' + $t('Importing and validating...') + '</span></div>');

                // Send AJAX request
                $.ajax({
                    url: importUrl,
                    type: 'POST',
                    data: {
                        json_data: jsonData,
                        form_key: window.FORM_KEY
                    },
                    dataType: 'json',
                    success: function(response) {
                        if (response.success) {
                            resultDiv.html(
                                '<div class="message message-success success"><span>' +
                                response.message +
                                '</span></div>'
                            );

                            // Clear file input
                            fileInput.value = '';

                            // Reload page after 2 seconds to show new data
                            setTimeout(function() {
                                location.reload();
                            }, 2000);
                        } else {
                            var errorHtml = '<div class="message message-error error"><span>' +
                                response.message +
                                '</span>';

                            if (response.errors && response.errors.length > 0) {
                                errorHtml += '<ul style="margin-top: 10px;">';
                                response.errors.forEach(function(error) {
                                    errorHtml += '<li>' + error + '</li>';
                                });
                                errorHtml += '</ul>';
                            }

                            errorHtml += '</div>';
                            resultDiv.html(errorHtml);
                        }
                    },
                    error: function(xhr, status, error) {
                        resultDiv.html(
                            '<div class="message message-error error"><span>' +
                            $t('Error during import: ') + error +
                            '</span></div>'
                        );
                    }
                });

            } catch (error) {
                alert({
                    title: $t('Error'),
                    content: $t('Error reading file: ') + error.message
                });
            }
        };

        reader.readAsText(file);
    });
});
</script>

